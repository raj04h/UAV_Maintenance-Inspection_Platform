    "        detection_thread.join()\n",
    "        stop_event.clear()\n",
    "        return jsonify({\"status\": \"Detection stopped\"})\n",
    "    else:\n",
    "        return jsonify({\"status\": \"No detection running\"})\n",
    "\n",
    "# Optional: base route to confirm server is running\n",
    "@app.route('/')\n",
    "def home():\n",
    "    return jsonify({\"message\": \"UAV Detection API is running.\"})\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    app.run(host=\"0.0.0.0\", port=5000)\n"
