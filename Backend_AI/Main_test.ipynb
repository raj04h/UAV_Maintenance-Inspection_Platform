    "part_model.to(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "defect_model.to(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "part_classNames = [\n",
    "    \"Attached Parts\", \"Body Fuselage\", \"Left Wing\", \"Payload Box\",\n",
    "    \"Propellers\", \"Right Wing\", \"Tail\", \"VTOL Arm\"\n",
    "]\n",
    "defect_classNames = ['crack', 'dent', 'missing-head', 'paint-off', 'scratch']\n",
    "colors = [\n",
    "    (255, 0, 0), (0, 255, 0), (0, 0, 255),\n",
    "    (0, 255, 255), (255, 0, 255), (255, 255, 0), (128, 0, 128), (0, 128, 255)\n",
    "]\n",
    "\n",
    "# Detection thread control\n",
    "detection_thread = None\n",
    "stop_event = threading.Event()\n",
    "\n",
    "def detect_from_stream(camera_url):\n",
    "    detections = []\n",
    "    camera = cv2.VideoCapture(camera_url)\n",
    "    if not camera.isOpened():\n",
    "        print(\"Camera not found\")\n",
    "        return\n",
    "\n",
    "    while not stop_event.is_set():\n",
    "        ret, frame = camera.read()\n",
    "        if not ret:\n",
    "            print(\"Frame not grabbed\")\n",
    "            break\n",
    "\n",
    "        img_copy = frame.copy()\n",
    "        h, w = img_copy.shape[:2]\n",
    "        max_dim = 1280\n",
    "        scale = min(max_dim / w, max_dim / h, 1)\n",
    "        img_display = cv2.resize(img_copy, (int(w * scale), int(h * scale)))\n",
    "\n",
    "        part_results = part_model(img_copy, conf=0.2, iou=0.5, imgsz=1280)[0]\n",
    "        defect_results = defect_model(img_copy, conf=0.1, iou=0.5, imgsz=1280)[0]\n",
    "\n",
    "        part_detections = []\n",
    "        for box in part_results.boxes:\n",
    "            x1, y1, x2, y2 = box.xyxy[0].cpu().numpy().astype(int)\n",
    "            part_detections.append({\n",
    "                \"bbox\": (x1, y1, x2, y2),\n",
    "                \"cls\": int(box.cls[0]),\n",
    "                \"conf\": float(box.conf[0])\n",
    "            })\n",
    "\n",
    "        for defect_box in defect_results.boxes:\n",
    "            x1, y1, x2, y2 = defect_box.xyxy[0].cpu().numpy().astype(int)\n",
    "            dx, dy = int(x1 * scale), int(y1 * scale)\n",
    "            dw, dh = int((x2 - x1) * scale), int((y2 - y1) * scale)\n",
    "\n",
    "            defect_cls = int(defect_box.cls[0])\n",
    "            defect_conf = float(defect_box.conf[0])\n",
    "            defect_name = defect_classNames[defect_cls] if defect_cls < len(defect_classNames) else str(defect_cls)\n",
    "            color = colors[defect_cls % len(colors)]\n",
    "\n",
    "            cvzone.cornerRect(img_display, (dx, dy, dw, dh), l=30, rt=3, colorR=color)\n",
    "            cvzone.putTextRect(\n",
    "                img_display,\n",
    "                f\"{defect_name} {defect_conf:.2f}\",\n",
    "                (dx, max(dy - 10, 10)),\n",
    "                scale=1.0, thickness=2,\n",
    "                colorR=color, colorT=(0, 0, 0),\n",
    "                font=cv2.FONT_HERSHEY_SIMPLEX,\n",
    "                offset=5, border=2, colorB=(255, 255, 255)\n",
    "            )\n",
    "\n",
    "            matched_part_name = \"Unknown\"\n",
    "            for part in part_detections:\n",
    "                px1, py1, px2, py2 = part[\"bbox\"]\n",
    "                if (x1 >= px1 and y1 >= py1 and x2 <= px2 and y2 <= py2):\n",
    "                    matched_part_name = part_classNames[part[\"cls\"]]\n",
    "                    break\n",
    "\n",
    "            timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "            detection_id = str(uuid.uuid4())[:8]\n",
    "            detections.append({\n",
    "                \"Detection_ID\": detection_id,\n",
    "                \"Part_Name\": matched_part_name,\n",
    "                \"Defect_Name\": defect_name,\n",
    "                \"Confidence\": round(defect_conf, 2),\n",
    "                \"Timestamp\": timestamp\n",
    "            })\n",
    "\n",
    "        cv2.imshow(\"Detections\", img_display)\n",
    "        if cv2.waitKey(1) & 0xFF == 27:  # ESC\n",
    "            break\n",
    "\n",
    "        if detections:\n",
    "            try:\n",
    "                df_old = pd.read_excel(excel_file, engine='openpyxl')\n",
    "            except Exception as e:\n",
    "                print(f\"Error reading Excel: {e}\")\n",
    "                df_old = pd.DataFrame(columns=[\"Detection_ID\", \"Part_Name\", \"Defect_Name\", \"Confidence\", \"Timestamp\"])\n",
    "\n",
    "            df_new = pd.DataFrame(detections)\n",
    "            pd.concat([df_old, df_new], ignore_index=True).to_excel(excel_file, index=False, engine='openpyxl')\n",
    "            detections.clear()\n",
    "\n",
    "    camera.release()\n",
    "    cv2.destroyAllWindows()\n",
    "\n",
    "@app.route('/detect_stream', methods=['POST'])\n",
    "def detect_stream():\n",
    "    global detection_thread, stop_event\n",
