    "import os\n",
    "import cv2\n",
    "import cvzone\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from ultralytics import YOLO\n",
    "from datetime import datetime\n",
    "import uuid\n",
    "import torch\n",
    "\n",
    "# Check CUDA availability\n",
    "print(\"CUDA Available:\", torch.cuda.is_available())\n",
    "if torch.cuda.is_available():\n",
    "    print(\"GPU Device:\", torch.cuda.get_device_name(0))\n",
    "\n",
    "# Create output directory and Excel file\n",
    "output_dir = \"uav_detection\"\n",
    "os.makedirs(output_dir, exist_ok=True)\n",
    "excel_file = os.path.join(output_dir, \"uav_parts.xlsx\")\n",
    "\n",
    "# Initialize Excel file with headers if it doesn't exist\n",
    "if not os.path.exists(excel_file):\n",
    "    pd.DataFrame(columns=[\"Detection_ID\", \"Part_Name\", \"Confidence\", \"Timestamp\"]).to_excel(excel_file, index=False)\n",
    "\n",
    "# Open video stream\n",
    "camera = cv2.VideoCapture(\"https://192.168.1.93:8080/video\")\n",
    "if not camera.isOpened():\n",
    "    print(\"Camera not found\")\n",
    "    exit()\n",
    "\n",
    "# Load YOLO model\n",
    "model = YOLO(r\"D:\\Himanshu_ML\\TE_UAV Projects\\TE_1 UAV MRO\\UAV_Parts\\runs\\detect\\exp_augmented3\\weights\\best.pt\")\n",
    "model.to(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "# Class names and box colors\n",
    "classNames = [\n",
    "    \"Attached Parts\", \"Body Fuselage\", \"Left Wing\", \"Payload Box\",\n",
    "    \"Propellers\", \"Right Wing\", \"Tail\", \"VTOL Arm\"\n",
    "    ]\n",
    "colors = [\n",
    "    (255, 0, 0), (0, 255, 0), (0, 0, 255),\n",
    "    (0, 255, 255), (255, 0, 255)\n",
    "]\n",
    "\n",
    "detections = []\n",
    "\n",
    "while True:\n",
    "    ret, frame = camera.read()\n",
    "    if not ret:\n",
    "        print(\"Frame not grabbed\")\n",
    "        break\n",
    "\n",
    "    # Prepare display image\n",
    "    img_copy = frame.copy()\n",
    "    h, w = img_copy.shape[:2]\n",
    "    max_dim = 1280\n",
    "    scale = min(max_dim/w, max_dim/h, 1)\n",
    "    img_display = cv2.resize(img_copy, (int(w*scale), int(h*scale)))\n",
    "\n",
    "    # Run inference\n",
    "    results = model(img_copy, conf=0.2, iou=0.5, imgsz=1280)[0]\n",
    "\n",
    "    # Process detections\n",
    "    for box in results.boxes:\n",
    "        x1, y1, x2, y2 = box.xyxy[0].cpu().numpy().astype(int)\n",
    "        dx, dy = int(x1*scale), int(y1*scale)\n",
    "        dw, dh = int((x2-x1)*scale), int((y2-y1)*scale)\n",
    "\n",
    "        cls = int(box.cls[0])\n",
    "        conf = float(box.conf[0])\n",
    "        part_name = classNames[cls] if cls < len(classNames) else str(cls)\n",
    "        color = colors[cls % len(colors)]\n",
    "\n",
    "        # Draw bounding box and label\n",
    "        cvzone.cornerRect(img_display, (dx, dy, dw, dh), l=30, rt=3, colorR=color)\n",
    "        cvzone.putTextRect(\n",
    "            img_display,\n",
    "            f\"{part_name} {conf:.2f}\",\n",
    "            (dx, max(dy-10, 10)),\n",
    "            scale=1.0, thickness=2,\n",
    "            colorR=color, colorT=(0,0,0),\n",
    "            font=cv2.FONT_HERSHEY_SIMPLEX,\n",
    "            offset=5, border=2, colorB=(255,255,255)\n",
    "        )\n",
    "\n",
    "        # Record detection data\n",
    "        timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "        detection_id = str(uuid.uuid4())[:8]\n",
    "        detections.append({\n",
    "            \"Detection_ID\": detection_id,\n",
    "            \"Part_Name\": part_name,\n",
    "            \"Confidence\": round(conf, 2),\n",
    "            \"Timestamp\": timestamp\n",
    "        })\n",
    "\n",
    "    # Display the frame\n",
    "    cv2.imshow(\"Detections\", img_display)\n",
    "    if cv2.waitKey(1) & 0xFF == 27:  # ESC key\n",
    "        break\n",
    "\n",
    "    # Write detections to Excel and clear list\n",
    "    if detections:\n",
    "        df_new = pd.DataFrame(detections)\n",
    "        df_old = pd.read_excel(excel_file)\n",
    "        pd.concat([df_old, df_new], ignore_index=True).to_excel(excel_file, index=False)\n",
    "        detections.clear()\n",
    "\n",
    "# Cleanup\n",
    "camera.release()\n",
    "cv2.destroyAllWindows()"
   ]
  },
